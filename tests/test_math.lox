import "native-modules/build/math.dll" as math;

print("=== Testing Math Module ===");
print("math.pi = " + str(math.pi));
print("math.e = " + str(math.e));
print("math.tau = " + str(math.tau));

print("Trigonometry:");
print("sin(pi/2) = " + str(math.sin(math.pi / 2)));
print("cos(pi) = " + str(math.cos(math.pi)));
print("tan(pi/4) = " + str(math.tan(math.pi / 4)));
print("asin(1) = " + str(math.asin(1)));
print("acos(-1) = " + str(math.acos(-1)));
print("atan(1) = " + str(math.atan(1)));
print("atan2(1, 1) = " + str(math.atan2(1, 1)));

print("Hyperbolic:");
print("sinh(1) = " + str(math.sinh(1)));
print("cosh(1) = " + str(math.cosh(1)));
print("tanh(1) = " + str(math.tanh(1)));

print("Exponential & Logarithmic:");
print("exp(1) = " + str(math.exp(1)));
print("log(e) = " + str(math.log(math.e)));
print("log10(100) = " + str(math.log10(100)));
print("log2(8) = " + str(math.log2(8)));

print("Power & Root:");
print("pow(2, 3) = " + str(math.pow(2, 3)));
print("sqrt(16) = " + str(math.sqrt(16)));

print("Rounding & Absolute:");
print("ceil(3.2) = " + str(math.ceil(3.2)));
print("floor(3.8) = " + str(math.floor(3.8)));
print("round(3.5) = " + str(math.round(3.5)));
print("round(3.4) = " + str(math.round(3.4)));
print("abs(-42.5) = " + str(math.abs(-42.5)));
